{
  "name": "skillmesh",
  "version": "0.1.0",
  "description": "A registry and manager for AI agent skills — install, update, link and compose skills (presets) from git, npm and local sources, following the agentskills.io standard.",
  "type": "module",
  "license": "MIT",
  "author": "Piotr Tarasiuk (https://github.com/piotar)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotar/skillmesh.git"
  },
  "homepage": "https://github.com/piotar/skillmesh#readme",
  "bugs": "https://github.com/piotar/skillmesh/issues",
  "keywords": [
    "ai",
    "agent",
    "agents",
    "skills",
    "skill",
    "agentskills",
    "skill-manager",
    "skill-registry",
    "registry",
    "cli",
    "package-manager",
    "dependency-manager",
    "install",
    "update",
    "link",
    "compose",
    "preset",
    "presets",
    "git",
    "npm",
    "claude",
    "codex",
    "gemini",
    "cursor"
  ],
  "bin": {
    "skillmesh": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "skillmesh": "bun run ./src/cli/index.ts",
    "build": "bun run ./scripts/build.ts",
    "start": "node ./dist/index.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "@types/cross-spawn": "6.0.6",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "dependencies": {
    "@clack/prompts": "1.6.0",
    "citty": "0.2.2",
    "cross-spawn": "7.0.6",
    "yaml": "2.9.0"
  }
}
